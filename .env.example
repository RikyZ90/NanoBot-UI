# NanoBot-UI environment variables
# Copy this file to .env and fill in your values

# ── UI ──────────────────────────────────────────────────────────────────────
# Port exposed by the web UI (default: 50002)
NANO_UI_PORT=50002

# Path to nanobot config.json on the host
NANOBOT_CONFIG_PATH=/home/ubuntu/lab/.nanobot/config.json

# Path to nanobot sessions directory on the host
NANOBOT_SESSIONS_DIR=/home/ubuntu/lab/.nanobot/workspace/sessions

# ── Telegram bridge ──────────────────────────────────────────────────────────
# The Telegram bot token and allowed_chat_id are configured directly inside
# nanobot's config.json under channels.telegram — NOT here.
# See README for the expected JSON structure.
